# ==============================================================
#  Lan Blackout — variáveis de ambiente
#  Copie este arquivo para ".env" e preencha os valores.
#  O arquivo ".env" NUNCA vai para o GitHub (está no .gitignore).
# ==============================================================

# Porta do servidor (local)
PORT=3000

# Domínio do seu site (quem pode chamar a API).
# Em testes pode deixar *  |  Em produção: https://documentos.lanblackout.com
ALLOWED_ORIGIN=*

# --- Grok (xAI) ---
# Gere uma chave NOVA no console da xAI: https://console.x.ai
XAI_API_KEY=
# Modelo a usar. Use o mais barato disponível no seu console (ex: grok-3-mini).
XAI_MODEL=grok-3-mini

# --- Mercado Pago ---
# Access Token da sua conta: https://www.mercadopago.com.br/developers/panel
# Comece com as credenciais de TESTE; depois troque pelas de produção.
MP_ACCESS_TOKEN=

# --- n8n ---
# URL do webhook que recebe os pedidos de contrato/declaração/procuração.
N8N_WEBHOOK_URL=
